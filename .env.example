# Express
SERVER_PORT=3000

# Environment
NODE_ENV=development

# JWT (not used in this project but kept for boilerplate compatibility)
SERVER_JWT=false
SERVER_JWT_SECRET=
SERVER_JWT_TIMEOUT=

# Database — get these from your Neon project dashboard
# Neon dashboard → Connection Details → switch to "Connection parameters"
DB_DIALECT=postgres
DB_HOST=ep-xxxx.us-east-2.aws.neon.tech
DB_USER=your_neon_user
DB_PASS=your_neon_password
DB_NAME=your_db_name

# AWS (not used in this project — region required by SDK to prevent crash)
AWS_KEYID=
AWS_SECRETKEY=
AWS_BUCKET=
AWS_REGION=us-east-1
